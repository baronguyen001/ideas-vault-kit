# Copy to .env and fill in your own values. .env is gitignored — never commit real keys.

# Optional: AI-assisted scoring (ivault score "<idea>" --suggest).
# Bring your own Gemini API key. Unset = the command prints "set GEMINI_API_KEY to enable".
GEMINI_API_KEY=your-gemini-api-key-here
# Optional override for the model used by --suggest (default: gemini-2.5-flash).
IVAULT_GEMINI_MODEL=gemini-2.5-flash

# Optional: Notion sync (ivault notion-sync). Requires the [notion] extra.
# Internal integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=your-notion-integration-token-here
# Target database (data source) id — the 32-char id from the database URL.
NOTION_DB=your-notion-database-id-here

# Optional: default vault directory used when --vault is omitted.
IVAULT_DIR=.
